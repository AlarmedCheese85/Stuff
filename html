<!-- SLIDE 1: TITLE -->
<div class="slide">
    <h1>All About<br>Dwarfism</h1>
    <p style="text-align: center; font-size: 28px; margin-top: 20px;">Exploring Achondroplasia & Genetic Growth</p>
